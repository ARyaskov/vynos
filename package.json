{
  "name": "vynos",
  "version": "0.2.0",
  "description": "Micropayments powered by Ethereum",
  "keywords": [
    "micropayments",
    "ethereum",
    "wallet"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.0.0",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:harness": "vite build --mode harness",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "smoke": "pnpm -s typecheck && pnpm -s build && node scripts/smoke-artifacts.mjs"
  },
  "files": [
    "dist/"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/react-transition-group": "^4.4.12",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "6.0.0-beta",
    "vite": "^6.3.0"
  },
  "dependencies": {
    "@mantine/core": "^7.17.8",
    "@mantine/hooks": "^7.17.8",
    "@tanstack/react-query": "^5.90.10",
    "@scure/bip32": "^1.7.0",
    "bip39": "^3.1.0",
    "buffer": "^6.0.3",
    "@riaskov/iohtee": "3.0.0",
    "@riaskov/iohtee-contracts": "6.1.0",
    "@reduxjs/toolkit": "^2.8.2",
    "browser-passworder": "^2.0.3",
    "html2canvas": "^1.4.1",
    "jdenticon": "^3.3.0",
    "localforage": "^1.10.0",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-draggable": "^4.4.6",
    "react-image": "^4.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.8.2",
    "react-transition-group": "^4.4.5",
    "scrypt-js": "^3.0.1",
    "timeparse": "^1.0.0",
    "viem": "^2.45.0",
    "wagmi": "^3.4.4"
  }
}
